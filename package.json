  },
  "version": "0.0.8",
  "scripts": {
    "build": "next build",
    "deploy": "bun run wrangler:deploy",
    "dev": "next dev",
    "fmt": "bun run prettier:write",
    "lint": "eslint . --ext ts",
    "start": "next start",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "bun run cf:build && opennextjs-cloudflare preview",
    "cf:deploy": "bun run cf:build && opennextjs-cloudflare deploy",
    "cf:upload": "bun run cf:build && opennextjs-cloudflare upload",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "supabase:init": "bunx supabase init",
    "supabase:db-push": "bunx supabase db push",
    "supabase:db-pull": "bunx supabase db pull",
    "supabase:db-reset": "bunx supabase db reset",
    "supabase:link": "bunx supabase link",
    "supabase:types": "bunx supabase gen types typescript --project-id gilqgzjkzkmhbbcqidqb --schema public > ./src/types/database.types/database.public.types.ts",
    "shadcn:add": "bunx shadcn@latest add",
    "shadcn:build": "bunx shadcn@latest build",
    "shadcn:init": "bunx shadcn@latest init",
    "vercel:link": "bunx vercel@latest link",
    "vercel:pull-env": "bunx vercel@latest env pull",
    "wrangler": "bunx wrangler@latest",
    "wrangler:build": "bunx wrangler@latest build",
    "wrangler:deploy": "bunx wrangler@latest deploy",
    "wrangler:typegen": "bunx wrangler@latest types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
